# OpenRouter API key — for resume parsing + form filling.
# Create one at https://openrouter.ai/keys. The app runs without it (heuristic fallback), just with lower accuracy.
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
# --- Different task, different model (best result, lowest cost) ---
# PARSE_MODEL: resume -> structured profile. Runs only once per resume,
#   so you can use a STRONG/accurate model here — cost is negligible.
PARSE_MODEL=anthropic/claude-3.5-sonnet
# FILL_MODEL: filling job forms. Runs on every job — a cheap but capable model.
FILL_MODEL=google/gemini-2.0-flash-001
# KEYWORDS_MODEL: suggest job keywords from the resume. Low-stakes — a free/cheap one works.
KEYWORDS_MODEL=google/gemini-2.0-flash-exp:free

# If you want fully free (but less accurate), replace all of the above with this:
#   meta-llama/llama-3.3-70b-instruct:free

PORT=4000

# --- Fill/apply phase (Puppeteer) ---
# Browser dikhe (review mode) ya background me chale. Default headed (false).
PUPPETEER_HEADLESS=false
# SAFETY GATE: real submit tabhi hoga jab ye true ho AUR UI/API submit:true bheje.
# Default false = sirf form bharo + screenshot lo, submit mat karo (review mode).
ALLOW_SUBMIT=false
