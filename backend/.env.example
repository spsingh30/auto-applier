# OpenRouter API key — resume ko structured JSON me parse karne ke liye.
# https://openrouter.ai/keys se banao. Na ho to bhi app chalega (heuristic fallback), bas accuracy kam.
OPENROUTER_API_KEY=

# OpenRouter model id (haiku sasta + tez; badi model zyada accurate)
LLM_MODEL=anthropic/claude-haiku-4.5

PORT=4000
