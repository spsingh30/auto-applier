# OpenRouter API key — resume ko structured JSON me parse karne ke liye.
# https://openrouter.ai/keys se banao. Na ho to bhi app chalega (heuristic fallback), bas accuracy kam.
OPENROUTER_API_KEY=

# OpenRouter model id. Default sabse sasta (FREE, $0).
# Accuracy ke liye badi model: anthropic/claude-haiku-4.5 ya google/gemini-2.0-flash-lite-001
LLM_MODEL=google/gemini-2.0-flash-exp:free

PORT=4000
