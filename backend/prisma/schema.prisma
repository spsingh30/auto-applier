// Prisma schema — SQLite for now (zero setup). Postgres + pgvector later for scale.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// A user's canonical profile — clean data extracted from the resume.
// This is the "heart" of the whole app; everything is read from here.
model Profile {
  id        String   @id @default(cuid())
  fullName  String?
  email     String?
  phone     String?
  location  String?
  linkedin  String?
  website   String?
  summary   String?
  skills    String?  // JSON string array (SQLite doesn't support native arrays)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  experiences  WorkExperience[]
  educations   Education[]
  resume       ResumeDocument?
  applications Application[]
}

model WorkExperience {
  id          String  @id @default(cuid())
  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company     String?
  title       String?
  startDate   String?
  endDate     String?
  description String?
}

model Education {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  school    String?
  degree    String?
  field     String?
  startDate String?
  endDate   String?
}

// Metadata + parse status of the original uploaded resume file.
model ResumeDocument {
  id          String   @id @default(cuid())
  profileId   String   @unique
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  fileName    String
  fileType    String
  parseStatus String   @default("PENDING") // PENDING | COMPLETED | FAILED
  createdAt   DateTime @default(now())
}

// "Where we're applying" — the dashboard's tracking part.
// "Where we're applying" + discovered jobs (from the crawler, not yet applied to).
// profileId optional: discovery is profile-independent; it gets linked to a profile at apply time.
model Application {
  id        String    @id @default(cuid())
  profileId String?
  profile   Profile?  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company   String
  jobTitle  String
  jobUrl    String?   @unique // dedup: avoid discovering the same job twice
  jobId     String?   // the ATS's own job id (greenhouse gh_jid, lever uuid, ...)
  location  String?
  ats       String?   // greenhouse | lever | ashby | workable | smartrecruiters
  status    String    @default("PENDING") // DISCOVERED | PENDING | FILLED | SUBMITTED | FAILED
  appliedAt DateTime?
  createdAt DateTime  @default(now())
}
