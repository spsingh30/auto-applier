// Prisma schema — SQLite for now (zero setup). Postgres + pgvector baad me scale ke liye.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Ek user ka canonical profile — resume se extract hua clean data.
// Yehi puri app ka "dil" hai; sab kuch isi se padha jaata hai.
model Profile {
  id        String   @id @default(cuid())
  fullName  String?
  email     String?
  phone     String?
  location  String?
  linkedin  String?
  github    String?
  website   String?
  summary   String?
  skills    String?  // JSON string array (SQLite native array support nahi karta)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  experiences  WorkExperience[]
  educations   Education[]
  resume       ResumeDocument?
  applications Application[]
}

model WorkExperience {
  id          String  @id @default(cuid())
  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company     String?
  title       String?
  startDate   String?
  endDate     String?
  description String?
}

model Education {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  school    String?
  degree    String?
  field     String?
  startDate String?
  endDate   String?
}

// Original uploaded resume file ki metadata + parse status.
model ResumeDocument {
  id          String   @id @default(cuid())
  profileId   String   @unique
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  fileName    String
  fileType    String
  storagePath String?  // disk pe saved file ka path — fill phase me ATS form pe attach karne ke liye
  parseStatus String   @default("PENDING") // PENDING | COMPLETED | FAILED
  createdAt   DateTime @default(now())
}

// "Hum kahan apply kar rahe hain" — dashboard ka tracking part.
// "Hum kahan apply kar rahe hain" + discovered jobs (crawler se aaye, abhi tak apply nahi).
// profileId optional: discovery profile-independent hai; apply karte time profile se jud jaata hai.
model Application {
  id        String    @id @default(cuid())
  profileId String?
  profile   Profile?  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company   String
  jobTitle  String
  jobUrl    String?   @unique // dedup: same job dobara discover na ho
  jobId     String?   // ATS ka apna job id (greenhouse gh_jid, lever uuid, ...)
  location  String?
  ats       String?   // greenhouse | lever | ashby | workable | smartrecruiters
  status    String    @default("PENDING") // DISCOVERED | PENDING | FILLED | SUBMITTED | FAILED
  appliedAt DateTime?
  createdAt DateTime  @default(now())

  // --- Fill/apply phase (Puppeteer) ---
  screenshotPath String?   // review ke liye bhari hui form ka screenshot
  fillNotes      String?   // JSON: { filled:[], skipped:[], answers:{}, error? } — debugging/review
  filledAt       DateTime?
}
